<?xml version="1.0" encoding="windows-1251"?>

<w>

	<!-- Full-screen dim background -->
	<background x="0" y="0" width="1024" height="768" stretch="1">
		<texture a="170" r="0" g="0" b="0">ui\ui_console</texture>
	</background>

	<!-- Main dialog frame -->
	<main x="202" y="129" width="620" height="510">

		<frame x="0" y="0" width="620" height="510" stretch="1">
			<texture>ui_options_background</texture>
		</frame>

		<title x="0" y="14" width="620" height="30">
			<text complex_mode="1" r="200" g="200" b="200" align="c" vert_align="c" font="graffiti22">st_seqload_title</text>
		</title>

		<caliber_label x="20" y="58" width="120" height="26">
			<text complex_mode="1" r="200" g="200" b="200" align="l" vert_align="c" font="letterica18">st_seqload_caliber</text>
		</caliber_label>

		<caliber_combo x="140" y="58" width="260" height="26">
			<list_font r="170" g="170" b="170" font="letterica16"/>
			<text_color>
				<e r="170" g="170" b="170"/>
				<d r="70" g="70" b="70"/>
			</text_color>
		</caliber_combo>

		<default_hint x="410" y="58" width="190" height="26">
			<text complex_mode="1" r="160" g="160" b="160" align="l" vert_align="c" font="letterica16">st_seqload_default_preset</text>
		</default_hint>

		<preset_label x="20" y="92" width="580" height="24">
			<text complex_mode="1" r="200" g="200" b="200" align="l" vert_align="c" font="letterica18">st_seqload_preset</text>
		</preset_label>

		<preset_list x="20" y="118" width="580" height="286"
		             right_ident="0" left_ident="0" top_indent="0" bottom_indent="0"
		             vert_interval="2" always_show_scroll="0"/>

		<add_combo x="20" y="414" width="380" height="26">
			<list_font r="170" g="170" b="170" font="letterica16"/>
			<text_color>
				<e r="170" g="170" b="170"/>
				<d r="70" g="70" b="70"/>
			</text_color>
		</add_combo>

		<btn_add x="410" y="414" width="190" height="26" stretch="1">
			<text align="c" vert_align="c" font="letterica18">st_seqload_add</text>
			<texture>ui_button_ordinary</texture>
		</btn_add>

		<btn_save x="180" y="460" width="130" height="32" stretch="1">
			<text align="c" vert_align="c" font="letterica18">st_seqload_save</text>
			<texture>ui_button_ordinary</texture>
		</btn_save>

		<btn_reset x="320" y="460" width="130" height="32" stretch="1">
			<text align="c" vert_align="c" font="letterica18">st_seqload_reset</text>
			<texture>ui_button_ordinary</texture>
		</btn_reset>

		<btn_close x="460" y="460" width="130" height="32" stretch="1">
			<text align="c" vert_align="c" font="letterica18">st_seqload_close</text>
			<texture>ui_button_ordinary</texture>
		</btn_close>

	</main>

	<!-- Row template: sub-elements are inflated once per row in Lua -->
	<row width="560" height="44">

		<bg x="0" y="0" width="560" height="44" stretch="1">
			<texture a="100" r="40" g="40" b="40">ui\ui_console</texture>
		</bg>

		<icon x="3" y="2" width="40" height="40" stretch="1"/>

		<name x="50" y="1" width="260" height="22">
			<text complex_mode="1" r="220" g="220" b="180" align="l" vert_align="c" font="letterica18"/>
		</name>

		<ammo_sec x="50" y="22" width="260" height="18">
			<text complex_mode="1" r="140" g="140" b="140" align="l" vert_align="c" font="letterica16"/>
		</ammo_sec>

		<btn_minus x="320" y="9" width="26" height="26" stretch="1">
			<text align="c" vert_align="c" font="graffiti19">-</text>
			<texture>ui_button_ordinary</texture>
		</btn_minus>

		<count_text x="348" y="9" width="46" height="26">
			<text complex_mode="1" r="240" g="240" b="140" align="c" vert_align="c" font="graffiti22"/>
		</count_text>

		<btn_plus x="396" y="9" width="26" height="26" stretch="1">
			<text align="c" vert_align="c" font="graffiti19">+</text>
			<texture>ui_button_ordinary</texture>
		</btn_plus>

		<btn_up x="432" y="2" width="70" height="20" stretch="1">
			<text align="c" vert_align="c" font="letterica16">^</text>
			<texture>ui_button_ordinary</texture>
		</btn_up>

		<btn_down x="432" y="22" width="70" height="20" stretch="1">
			<text align="c" vert_align="c" font="letterica16">v</text>
			<texture>ui_button_ordinary</texture>
		</btn_down>

		<btn_remove x="510" y="9" width="46" height="26" stretch="1">
			<text align="c" vert_align="c" font="letterica18">X</text>
			<texture>ui_button_ordinary</texture>
		</btn_remove>

	</row>

</w>
